{
  "name": "tienda-web-lotoai",
  "version": "1.0.0",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:frontend": "ng build --configuration production",
    "build:backend": "cd src/backend && npm install && npm run build",
    "start": "ng serve",
    "start:prod": "node dist/tienda-web-loto-ai/server/main.js",
    "_preinstall": "npm install -g @angular/cli",
    "deploy:frontend": "bash scripts/deploy-frontend.sh",
    "dev": "ng serve --configuration development",
    "dev:ssr": "ng run tienda-web-loto-ai:serve-ssr:development",
    "dev:backend": "cd src/backend && npm run dev",
    "fix-ssr": "node fix-ssr.js",
    "serve:ssr": "node dist/tienda-web-loto-ai/server/main.js",
    "serve:ssr:dev": "ng run tienda-web-loto-ai:serve-ssr:development",
    "build:ssr": "ng build && ng run tienda-web-loto-ai:server",
    "prerender": "ng run tienda-web-loto-ai:prerender",
    "clean": "rimraf dist node_modules package-lock.json",
    "clean:all": "npm run clean && cd src/backend && npm run clean"
  },
  "dependencies": {
    "@angular/animations": "^18.2.12",
    "@angular/common": "^18.2.12",
    "@angular/compiler": "^18.2.12",
    "@angular/core": "^18.2.12",
    "@angular/forms": "^18.2.12",
    "@angular/platform-browser": "^18.2.12",
    "@angular/platform-browser-dynamic": "^18.2.12",
    "@angular/platform-server": "^18.2.12",
    "@angular/router": "^18.2.12",
    "@angular/ssr": "^18.2.14",
    "@types/bcrypt": "^5.0.2",
    "@types/express-session": "^1.18.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/pg": "^8.11.11",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "domino": "^2.1.6",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "jsonwebtoken": "^9.0.2",
    "node-mailjet": "^6.0.7",
    "pg": "^8.13.3",
    "puppeteer": "^24.2.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.12",
    "@angular/cli": "^18.2.12",
    "@angular/compiler-cli": "^18.2.12",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.64",
    "browser-sync": "^3.0.0",
    "jasmine-core": "~5.1.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.5.4",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.4.2"
  }
}
